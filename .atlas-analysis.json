  "keyFeatures": [
    "Multi-role governance system with proposers, improvers, voters, and issuers",
    "Workflow builder with sequential steps and bounty management",
    "Voting system with quorum requirements and 24-hour countdown",
    "Credential-based role requirements for workflow steps",
    "Merchant location mapping and payment integration",
    "W9 compliance workflow with webhook integration",
    "Token wrapping/unwrapping functionality",
    "Affiliate event management and payout scheduling",
    "Blockchain indexing via Ponder for ERC20 events",
    "Smart account integration with Privy authentication"
  ],
  "publicApiSurface": [
    "POST /users - Create user account",
    "GET /users - Get authenticated user info",
    "POST /proposers/workflows - Create workflow proposal",
    "GET /improvers/workflows - Get available workflows for improvers",
    "POST /improvers/workflows/{id}/steps/{step_id}/claim - Claim workflow step",
    "POST /voters/workflows/{id}/vote - Vote on workflow proposal",
    "POST /issuers/credentials - Grant credentials to users",
    "GET /locations - Get merchant locations",
    "POST /affiliates/events - Create affiliate event",
    "GET /admin/users - Admin: Get all users",
    "POST /w9/webhook - Webhook: Submit W9 compliance form",
    "POST /unwrap - Request token unwrapping",
    "POST /redeem - Redeem faucet QR code"
  ]
